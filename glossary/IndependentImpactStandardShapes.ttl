@prefix data: <https://jellyfiiish.xyz/ns/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix impact: <https://w3id.org/impactont/> .
@prefix indimp: <https://independentimpact.org/ns/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

indimp:LicenseNumberShape a sh:NodeShape ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path indimp:licenseNumber ;
            sh:pattern "^II-(PD|PV|MV)-[0-9]{2}X[0-9]{2}X[0-9]{11}-[0-9]{8}$" ] ;
    sh:targetClass indimp:AgentLicense .

indimp:authProofShape a sh:NodeShape ;
    sh:property [ sh:class skos:Concept ;
            sh:in ( indimp:none indimp:eddsa-signature indimp:rsa-signature indimp:vc ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path indimp:authProof ] ;
    sh:targetClass data:Document .

indimp:beneficialOrAdverseShape a sh:NodeShape ;
    sh:property [ sh:class skos:Concept ;
            sh:in ( indimp:beneficial indimp:adverse ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path indimp:beneficialOrAdverse ] ;
    sh:targetClass impact:Impact .

indimp:impactIntentionalityShape a sh:NodeShape ;
    sh:property [ sh:class skos:Concept ;
            sh:in ( indimp:intentional indimp:unintentional ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path indimp:impactIntentionality ] ;
    sh:targetClass impact:Impact .

indimp:licenseScopeShape a sh:NodeShape ;
    sh:property [ sh:class skos:Concept ;
            sh:in ( indimp:project-developer indimp:pdd-validator indimp:mr-verifier ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path indimp:licenseScope ] ;
    sh:targetClass indimp:AgentLicense .

indimp:monitoredShape a sh:NodeShape ;
    sh:property [ sh:class skos:Concept ;
            sh:in ( indimp:yes indimp:no ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path indimp:monitored ] ;
    sh:targetClass impact:Impact .

indimp:resourceIpfsUriShape a sh:NodeShape ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path indimp:resourceIpfsUri ;
            sh:pattern "^(ipfs|ipns)://[a-zA-Z0-9]+(?:/[a-zA-Z0-9/._-]*)?$" ] ;
    sh:targetClass dcterms:Resource .

indimp:techMeasTypeShape a sh:NodeShape ;
    sh:property [ sh:class skos:Concept ;
            sh:in ( indimp:facility indimp:system indimp:equipment indimp:other ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path indimp:techMeasType ] ;
    sh:targetClass indimp:TechnologyOrMeasure .

indimp:userTypeShape a sh:NodeShape ;
    sh:property [ sh:class skos:Concept ;
            sh:in ( indimp:standard-registry indimp:user ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path indimp:userType ] ;
    sh:targetClass indimp:PlatformUser .

